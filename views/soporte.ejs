<% /* Pre-evaluar variables dinámicas ANTES del template literal */ var _errors=(typeof errors !=='undefined' &&
  Array.isArray(errors)) ? errors : []; var _fd=(typeof formData !=='undefined' && formData) ? formData : { nombre: '' ,
  correo: '' , empresa: '' , asunto: '' , descripcion: '' }; %>
  <%- include('layout', {body: ` <!-- ══════════════════════════════════════════════════ Estilos de la página de soporte
    ═══════════════════════════════════════════════════ -->
    <style>
      /* ─── Hero ───────────────────────────────────────── */
      .soporte-hero {
        padding: 140px 0 60px;
        background: linear-gradient(135deg, #0f2e42 0%, #003655 50%, #00291f 100%);
        position: relative;
        overflow: hidden;
        text-align: center;
      }

      .soporte-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 50% at 80% 20%, rgba(0, 186, 178, 0.12) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 10% 80%, rgba(0, 76, 119, 0.18) 0%, transparent 60%);
        pointer-events: none;
      }

      .soporte-hero-content {
        position: relative;
        z-index: 2;
        max-width: 680px;
        margin: 0 auto;
        padding: 0 20px;
      }

      .soporte-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(0, 186, 178, 0.15);
        border: 1px solid rgba(0, 186, 178, 0.35);
        border-radius: 50px;
        padding: 0.35rem 1.1rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: #00eae3;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 1.4rem;
      }

      .soporte-hero h1 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        color: #fff;
        line-height: 1.2;
        margin-bottom: 1rem;
      }

      .soporte-hero p {
        font-size: 1.05rem;
        color: rgba(255, 255, 255, 0.75);
        max-width: 520px;
        margin: 0 auto;
      }

      /* ─── Layout principal ───────────────────────────── */
      .soporte-section {
        padding: 64px 0 80px;
        background: #1e1b1b;
      }

      .soporte-layout {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 3rem;
        align-items: start;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }

      /* ─── Panel lateral ──────────────────────────────── */
      .soporte-info {
        position: sticky;
        top: 100px;
      }

      .soporte-info-card {
        background: rgba(45, 42, 42, 0.6);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.2rem;
        padding: 2rem;
        margin-bottom: 1.5rem;
      }

      .soporte-info-card h3 {
        font-size: 1rem;
        color: #00eae3;
        margin-bottom: 1rem;
      }

      .info-item {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        margin-bottom: 1.1rem;
      }

      .info-item:last-child {
        margin-bottom: 0;
      }

      .info-icon {
        width: 36px;
        height: 36px;
        min-width: 36px;
        background: rgba(0, 186, 178, 0.12);
        border: 1px solid rgba(0, 186, 178, 0.25);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00bab2;
      }

      .info-icon svg {
        width: 18px;
        height: 18px;
      }

      .info-text strong {
        display: block;
        font-size: 0.88rem;
        color: #fff;
        margin-bottom: 0.2rem;
      }

      .info-text span {
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.55);
        line-height: 1.4;
      }

      /* Steps */
      .soporte-steps {
        counter-reset: step;
      }

      .soporte-step {
        display: flex;
        align-items: flex-start;
        gap: 0.9rem;
        margin-bottom: 1rem;
      }

      .step-num {
        counter-increment: step;
        min-width: 26px;
        height: 26px;
        background: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 700;
        color: #fff;
        margin-top: 2px;
      }

      .step-num::before {
        content: counter(step);
      }

      .soporte-step p {
        font-size: 0.84rem;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
        line-height: 1.5;
      }

      /* ─── Tarjeta del formulario ─────────────────────── */
      .soporte-form-card {
        background: rgba(45, 42, 42, 0.6);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.2rem;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
      }

      .soporte-form-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #00bab2, #00eae3, #004d49, #00bab2);
        background-size: 200% 100%;
        animation: shimmer-bar 3s linear infinite;
      }

      @keyframes shimmer-bar {
        0% {
          background-position: 200% 0;
        }

        100% {
          background-position: -200% 0;
        }
      }

      .soporte-form-card h2 {
        font-size: 1.3rem;
        color: #fff;
        margin-bottom: 0.4rem;
      }

      .form-subtitle {
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 2rem;
      }

      /* ─── Grid de campos ─────────────────────────────── */
      .form-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
      }

      .form-group {
        margin-bottom: 0;
      }

      .form-group.full-width {
        grid-column: 1 / -1;
      }

      .form-group label {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.83rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .required-dot {
        color: #f87171;
        font-size: 1rem;
        line-height: 1;
      }

      .optional-badge {
        font-size: 0.7rem;
        font-weight: 500;
        background: rgba(156, 163, 175, 0.15);
        color: #9ca3af;
        padding: 1px 7px;
        border-radius: 50px;
        text-transform: none;
        letter-spacing: 0;
      }

      .form-group input,
      .form-group textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.04);
        color: var(--text);
        padding: 0.82rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.6rem;
        font-family: inherit;
        font-size: 0.95rem;
        transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
        outline: none;
      }

      .form-group input::placeholder,
      .form-group textarea::placeholder {
        color: rgba(255, 255, 255, 0.25);
      }

      .form-group input:focus,
      .form-group textarea:focus {
        border-color: var(--primary);
        background: rgba(0, 186, 178, 0.04);
        box-shadow: 0 0 0 3px rgba(0, 186, 178, 0.12);
      }

      .form-group input.error-field,
      .form-group textarea.error-field {
        border-color: #f87171;
        box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.1);
      }

      .form-group textarea {
        min-height: 140px;
        resize: vertical;
      }

      /* ─── Upload ─────────────────────────────────────── */
      .file-upload-area {
        border: 2px dashed rgba(255, 255, 255, 0.12);
        border-radius: 0.8rem;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.25s;
        background: rgba(255, 255, 255, 0.02);
        position: relative;
      }

      .file-upload-area:hover,
      .file-upload-area.dragover {
        border-color: var(--primary);
        background: rgba(0, 186, 178, 0.05);
      }

      .file-upload-area input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
      }

      .file-upload-icon {
        color: var(--primary);
        margin-bottom: 0.5rem;
      }

      .file-upload-icon svg {
        width: 32px;
        height: 32px;
      }

      .file-upload-text {
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.5;
      }

      .file-upload-text strong {
        color: var(--primary);
      }

      .file-selected-info {
        display: none;
        align-items: center;
        gap: 0.6rem;
        margin-top: 0.8rem;
        background: rgba(0, 186, 178, 0.1);
        border: 1px solid rgba(0, 186, 178, 0.25);
        border-radius: 0.5rem;
        padding: 0.5rem 0.9rem;
        font-size: 0.83rem;
        color: #00eae3;
      }

      .file-selected-info.active {
        display: flex;
      }

      /* ─── Alertas de error ───────────────────────────── */
      .alert-errors {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 0.7rem;
        padding: 1rem 1.2rem;
        margin-bottom: 1.5rem;
      }

      .alert-errors .alert-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.88rem;
        font-weight: 700;
        color: #f87171;
        margin-bottom: 0.5rem;
      }

      .alert-errors ul {
        list-style: disc;
        padding-left: 1.2rem;
      }

      .alert-errors ul li {
        font-size: 0.83rem;
        color: rgba(248, 113, 113, 0.9);
        margin-bottom: 0.25rem;
      }

      /* ─── Botón enviar ───────────────────────────────── */
      .btn-submit-soporte {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: #fff;
        border: none;
        padding: 0.9rem 2.2rem;
        border-radius: 50px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        transition: all 0.3s ease;
        width: 100%;
        margin-top: 1.2rem;
        font-family: inherit;
        letter-spacing: 0.02em;
        position: relative;
        overflow: hidden;
      }

      .btn-submit-soporte::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, transparent 100%);
        opacity: 0;
        transition: opacity 0.3s;
      }

      .btn-submit-soporte:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 186, 178, 0.35);
      }

      .btn-submit-soporte:hover::after {
        opacity: 1;
      }

      .btn-submit-soporte:active {
        transform: translateY(0);
      }

      .btn-submit-soporte.loading {
        pointer-events: none;
        opacity: 0.8;
      }

      .btn-submit-soporte svg.btn-send-icon {
        width: 20px;
        height: 20px;
        transition: transform 0.3s;
      }

      .btn-submit-soporte:hover svg.btn-send-icon {
        transform: translateX(3px);
      }

      .spinner {
        display: none;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .btn-submit-soporte.loading .spinner {
        display: block;
      }

      .btn-submit-soporte.loading .btn-send-icon {
        display: none;
      }

      /* ─── Nota privacidad ────────────────────────────── */
      .form-privacy-note {
        text-align: center;
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.35);
        margin-top: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
      }

      /* ─── Responsive ─────────────────────────────────── */
      @media (max-width: 900px) {
        .soporte-layout {
          grid-template-columns: 1fr;
        }

        .soporte-info {
          position: static;
        }

        .form-grid-2 {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 480px) {
        .soporte-form-card {
          padding: 1.8rem 1.2rem;
        }
      }
    </style>

    <!-- ══════════════════════════════════════════════════
     Hero
═══════════════════════════════════════════════════ -->
    <section class="soporte-hero">
      <div class="soporte-hero-content">
        <div class="soporte-hero-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
          </svg>
          Mesa de Ayuda &middot; SATEM
        </div>
        <h1>Soporte al Cliente</h1>
        <p>Completa el formulario con tu requerimiento y nuestro equipo te responderá a la brevedad.</p>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════
     Sección del formulario
═══════════════════════════════════════════════════ -->
    <section class="soporte-section">
      <div class="soporte-layout">

        <!-- ── Panel lateral de información ────────────── -->
        <aside class="soporte-info">
          <div class="soporte-info-card">
            <h3>¿Cómo funciona?</h3>
            <div class="soporte-steps">
              <div class="soporte-step">
                <div class="step-num"></div>
                <p>Completa el formulario con la información de tu requerimiento.</p>
              </div>
              <div class="soporte-step">
                <div class="step-num"></div>
                <p>Tu solicitud se convierte automáticamente en un ticket de Soporte.</p>
              </div>
              <div class="soporte-step">
                <div class="step-num"></div>
                <p>Nuestro equipo analiza y gestiona tu caso en la mesa de ayuda.</p>
              </div>
              <div class="soporte-step">
                <div class="step-num"></div>
                <p>Recibirás la respuesta directamente en tu correo electrónico.</p>
              </div>
            </div>
          </div>

          <div class="soporte-info-card">
            <h3>Contacto directo</h3>
            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
              </div>
              <div class="info-text">
                <strong>Correo</strong>
                <span>soporte@satemsoluciones.com</span>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.49 12 19.79 19.79 0 0 1 1.27 3.47 2 2 0 0 1 3.22 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8 8a16 16 0 0 0 6 6l.36-.36a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </div>
              <div class="info-text">
                <strong>Teléfono</strong>
                <span>+56 9 7190 7865</span>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
              </div>
              <div class="info-text">
                <strong>Tiempo de respuesta</strong>
                <span>En el mismo día hábil, dentro del horario laboral.</span>
              </div>
            </div>
          </div>
        </aside>

        <!-- ── Formulario principal ─────────────────────── -->
        <div class="soporte-form-card">
          <h2>Nueva Solicitud de Soporte</h2>
          <p class="form-subtitle">
            Los campos con <span style="color:#f87171;">*</span> son obligatorios.
          </p>

          <!-- Contenedor de errores del servidor (poblado por JS) -->
          <div class="alert-errors" id="server-errors-box" style="display:none;">
            <div class="alert-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
              </svg>
              Por favor corrige los siguientes errores:
            </div>
            <ul id="server-errors-list"></ul>
          </div>

          <form id="soporte-form" action="/soporte" method="POST" enctype="multipart/form-data" novalidate>

            <div class="form-grid-2">

              <!-- Nombre -->
              <div class="form-group">
                <label for="nombre">
                  Nombre completo <span class="required-dot">*</span>
                </label>
                <input type="text" id="nombre" name="nombre" placeholder="Juan Pérez" maxlength="120"
                  autocomplete="name" required>
                <div class="field-error" id="error-nombre"
                  style="display:none;font-size:0.78rem;color:#f87171;margin-top:0.35rem;"></div>
              </div>

              <!-- Correo -->
              <div class="form-group">
                <label for="correo">
                  Correo electrónico <span class="required-dot">*</span>
                </label>
                <input type="email" id="correo" name="correo" placeholder="juan@empresa.com" maxlength="200"
                  autocomplete="email" required>
                <div class="field-error" id="error-correo"
                  style="display:none;font-size:0.78rem;color:#f87171;margin-top:0.35rem;"></div>
              </div>

              <!-- Empresa -->
              <div class="form-group">
                <label for="empresa">
                  Empresa <span class="required-dot">*</span>
                </label>
                <input type="text" id="empresa" name="empresa" placeholder="Mi Empresa S.A." maxlength="150"
                  autocomplete="organization" required>
                <div class="field-error" id="error-empresa"
                  style="display:none;font-size:0.78rem;color:#f87171;margin-top:0.35rem;"></div>
              </div>

              <!-- Asunto -->
              <div class="form-group">
                <label for="asunto">
                  Asunto del ticket <span class="required-dot">*</span>
                </label>
                <input type="text" id="asunto" name="asunto" placeholder="Ej: Error al generar reportes" maxlength="200"
                  required>
                <div class="field-error" id="error-asunto"
                  style="display:none;font-size:0.78rem;color:#f87171;margin-top:0.35rem;"></div>
              </div>

              <!-- Descripción -->
              <div class="form-group full-width">
                <label for="descripcion">
                  Descripción detallada <span class="required-dot">*</span>
                </label>
                <textarea id="descripcion" name="descripcion"
                  placeholder="Describe con detalle el problema o requerimiento. Incluye pasos para reproducirlo si aplica."
                  maxlength="5000" required></textarea>
                <div class="field-error" id="error-descripcion"
                  style="display:none;font-size:0.78rem;color:#f87171;margin-top:0.35rem;"></div>
                <div style="text-align:right;font-size:0.74rem;color:rgba(255,255,255,0.3);margin-top:0.3rem;">
                  <span id="char-count">0</span>/5000
                </div>
              </div>

              <!-- Adjunto -->
              <div class="form-group full-width">
                <label>
                  Archivo adjunto <span class="optional-badge">Opcional</span>
                </label>
                <div class="file-upload-area" id="file-upload-area">
                  <input type="file" id="adjunto" name="adjunto"
                    accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip">
                  <div class="file-upload-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                      <polyline points="17 8 12 3 7 8" />
                      <line x1="12" y1="3" x2="12" y2="15" />
                    </svg>
                  </div>
                  <div class="file-upload-text">
                    <strong>Haz clic o arrastra</strong> tu archivo aquí<br>
                    <span style="font-size:0.75rem;">JPG, PNG, PDF, DOC, XLS, TXT, ZIP &mdash; Máx. 10 MB</span>
                  </div>
                </div>
                <div class="file-selected-info" id="file-selected-info">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                  </svg>
                  <span id="file-name-display"></span>
                  <button type="button" onclick="clearFile()" style="margin-left:auto;background:none;border:none;cursor:pointer;
                       color:rgba(255,255,255,0.4);font-size:1.1rem;line-height:1;padding:0 0 0 0.5rem;">
                    &times;
                  </button>
                </div>
                <div class="field-error" id="error-adjunto"
                  style="display:none;font-size:0.78rem;color:#f87171;margin-top:0.35rem;"></div>
              </div>

            </div><!-- /form-grid-2 -->

            <button type="submit" class="btn-submit-soporte" id="submit-btn">
