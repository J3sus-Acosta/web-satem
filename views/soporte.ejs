    <!-- ══════════════════════════════════════════════════
     Datos del servidor inyectados de forma segura
═══════════════════════════════════════════════════ -->
    <script>
      /* Variables serializadas desde EJS antes del template literal */
      var __SP_ERRORS = ${ JSON.stringify(_errors) };
      var __SP_FORMDATA = ${ JSON.stringify(_fd) };
    </script>

    <!-- ══════════════════════════════════════════════════
     Lógica del formulario
═══════════════════════════════════════════════════ -->
    <script>
      (function () {
        var ALLOWED_EXT = /\\.(jpg|jpeg|png|gif|webp|pdf|doc|docx|xls|xlsx|txt|zip)$/i;
        var MAX_MB = 10;

        /* ── Restaurar valores del formulario (repoblación tras error) ── */
        if (__SP_FORMDATA) {
          var fd = __SP_FORMDATA;
          if (fd.nombre) document.getElementById('nombre').value = fd.nombre;
          if (fd.correo) document.getElementById('correo').value = fd.correo;
          if (fd.empresa) document.getElementById('empresa').value = fd.empresa;
          if (fd.asunto) document.getElementById('asunto').value = fd.asunto;
          if (fd.descripcion) {
            var ta = document.getElementById('descripcion');
            ta.value = fd.descripcion;
            document.getElementById('char-count').textContent = fd.descripcion.length;
          }
        }

        /* ── Mostrar errores del servidor ───────────────────────────── */
        if (__SP_ERRORS && __SP_ERRORS.length > 0) {
          var box = document.getElementById('server-errors-box');
          var list = document.getElementById('server-errors-list');
          __SP_ERRORS.forEach(function (msg) {
            var li = document.createElement('li');
            li.textContent = msg;
            list.appendChild(li);
          });
          box.style.display = 'block';
          box.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        /* ── Contador de caracteres ─────────────────────────────────── */
        var textarea = document.getElementById('descripcion');
        var charCount = document.getElementById('char-count');
        if (textarea) {
          textarea.addEventListener('input', function () {
            charCount.textContent = this.value.length;
          });
        }

        /* ── Drag & Drop ─────────────────────────────────────────────── */
        var dropArea = document.getElementById('file-upload-area');
        var fileInput = document.getElementById('adjunto');

        if (dropArea) {
          dropArea.addEventListener('dragover', function (e) {
            e.preventDefault();
            dropArea.classList.add('dragover');
          });
          dropArea.addEventListener('dragleave', function () {
            dropArea.classList.remove('dragover');
          });
          dropArea.addEventListener('drop', function (e) {
            e.preventDefault();
            dropArea.classList.remove('dragover');
            if (e.dataTransfer.files.length) {
              fileInput.files = e.dataTransfer.files;
              handleFileChange(fileInput.files[0]);
            }
          });
        }

        if (fileInput) {
          fileInput.addEventListener('change', function () {
            if (this.files.length) handleFileChange(this.files[0]);
          });
        }

        function handleFileChange(file) {
          hideError('adjunto');
          if (!ALLOWED_EXT.test(file.name)) {
            showError('adjunto', 'Tipo de archivo no permitido. Usa JPG, PNG, PDF, DOC, XLS, TXT o ZIP.');
            clearFile(); return;
          }
          if (file.size > MAX_MB * 1024 * 1024) {
            showError('adjunto', 'El archivo supera los ' + MAX_MB + ' MB permitidos.');
            clearFile(); return;
          }
          var sizeMB = (file.size / (1024 * 1024)).toFixed(2);
          document.getElementById('file-name-display').textContent = file.name + ' (' + sizeMB + ' MB)';
          document.getElementById('file-selected-info').classList.add('active');
        }

        window.clearFile = function () {
          if (fileInput) fileInput.value = '';
          document.getElementById('file-selected-info').classList.remove('active');
          hideError('adjunto');
        };

        /* ── Validación frontend ─────────────────────────────────────── */
        var form = document.getElementById('soporte-form');
        if (form) {
          form.addEventListener('submit', function (e) {
            var valid = true;

            var nombre = document.getElementById('nombre');
            if (!nombre.value.trim() || nombre.value.trim().length < 2) {
              showError('nombre', 'El nombre es obligatorio (mínimo 2 caracteres).'); valid = false;
            } else hideError('nombre');

            var correo = document.getElementById('correo');
            if (!correo.value.trim() || !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$/.test(correo.value.trim())) {
              showError('correo', 'Ingresa un correo electrónico válido.'); valid = false;
            } else hideError('correo');

            var empresa = document.getElementById('empresa');
            if (!empresa.value.trim() || empresa.value.trim().length < 2) {
              showError('empresa', 'El nombre de la empresa es obligatorio.'); valid = false;
            } else hideError('empresa');

            var asunto = document.getElementById('asunto');
            if (!asunto.value.trim() || asunto.value.trim().length < 4) {
              showError('asunto', 'El asunto debe tener al menos 4 caracteres.'); valid = false;
            } else hideError('asunto');

            var desc = document.getElementById('descripcion');
            if (!desc.value.trim() || desc.value.trim().length < 10) {
              showError('descripcion', 'La descripción debe tener al menos 10 caracteres.'); valid = false;
            } else hideError('descripcion');

            if (!valid) {
              e.preventDefault();
              var first = document.querySelector('.error-field');
              if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
              return;
            }

            /* Activar estado loading */
            var btn = document.getElementById('submit-btn');
            btn.classList.add('loading');
            document.getElementById('submit-label').textContent = 'Enviando...';
          });
        }

        /* ── Limpieza on-input ───────────────────────────────────────── */
        ['nombre', 'correo', 'empresa', 'asunto', 'descripcion'].forEach(function (id) {
          var el = document.getElementById(id);
          if (el) el.addEventListener('input', function () { hideError(id); });
        });

        /* ── Helpers ─────────────────────────────────────────────────── */
        function showError(fieldId, msg) {
          var errEl = document.getElementById('error-' + fieldId);
          var input = document.getElementById(fieldId);
          if (errEl) { errEl.textContent = msg; errEl.style.display = 'block'; }
          if (input) input.classList.add('error-field');
        }
        function hideError(fieldId) {
          var errEl = document.getElementById('error-' + fieldId);
          var input = document.getElementById(fieldId);
          if (errEl) errEl.style.display = 'none';
          if (input) input.classList.remove('error-field');
        }

      })();
    </script>

    `}) %>