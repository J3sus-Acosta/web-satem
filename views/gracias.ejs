.success-header p {
    font-size: 1.05rem;
    opacity: 0.75;
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
}

/* --- CTA final --- */
.ty-cta {
    padding: 5rem 1.5rem;
    text-align: center;
}

.ty-cta h2 {
    font-family: 'Baloo 2', sans-serif;
