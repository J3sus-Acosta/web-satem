<%- include('layout', {title: '¡Consultoría Agendada! | SATEM Soluciones Inteligentes', body: `

<style>
/* ============================================
   THANK YOU PAGE — CUSTOM STYLES
============================================ */

.ty-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
}

.ty-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 80% 60% at 50% 0%, rgba(99, 102, 241, 0.25) 0%, transparent 70%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(16, 185, 129, 0.15) 0%, transparent 60%);
    pointer-events: none;
}

.ty-hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
}

.ty-check-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
}

.ty-check {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 40px rgba(16, 185, 129, 0.4);
    animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes popIn {
    0%   { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
}

.ty-check svg {
    width: 44px;
    height: 44px;
    stroke: #fff;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
}

.ty-hero h1 {
    font-family: 'Baloo 2', sans-serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.2rem;
    background: linear-gradient(135deg, #fff 30%, #a5b4fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.ty-hero p {
    font-size: 1.15rem;
    opacity: 0.85;
    line-height: 1.7;
}

/* --- Instrucciones --- */
.instructions-section {
    padding: 4rem 1.5rem;
}

.instructions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
}

.step-card {
