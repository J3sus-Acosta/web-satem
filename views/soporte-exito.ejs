<%- include('layout', {body: ` <style>
  .exito-section {
  min-height: calc(100vh - 80px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 80px;
  background: linear-gradient(135deg, #0f2e42 0%, #003655 50%, #00291f 100%);
  position: relative;
  overflow: hidden;
  }

  .exito-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
  radial-gradient(ellipse 60% 50% at 70% 20%, rgba(0,186,178,0.1) 0%, transparent 60%),
  radial-gradient(ellipse 40% 40% at 20% 80%, rgba(0,76,119,0.15) 0%, transparent 60%);
  pointer-events: none;
  }

  /* Partículas decorativas */
  .exito-section::after {
  content: '';
  position: absolute;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  border: 1px solid rgba(0,186,178,0.08);
  top: 10%;
  right: 5%;
  animation: pulse-ring 4s ease-in-out infinite;
  }

  @keyframes pulse-ring {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 1; }
  }

  .exito-card {
  position: relative;
  z-index: 2;
  background: rgba(45,42,42,0.65);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 1.5rem;
  padding: 3.5rem 3rem;
  max-width: 560px;
  width: 100%;
  text-align: center;
  box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,186,178,0.1);
  animation: slideUpCard 0.6s cubic-bezier(0.34,1.56,0.64,1) both;
  }

  @keyframes slideUpCard {
  from { opacity: 0; transform: translateY(40px) scale(0.96); }
  to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .exito-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #00bab2, #00eae3, #004d49, #00bab2);
  background-size: 200% 100%;
  animation: shimmer 3s linear infinite;
  border-radius: 1.5rem 1.5rem 0 0;
  }

  @keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
  }

  /* Ícono de éxito animado */
  .success-icon-wrap {
  position: relative;
  width: 90px;
  height: 90px;
  margin: 0 auto 2rem;
  }

  .success-icon-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(0,186,178,0.12);
  border: 2px solid rgba(0,186,178,0.3);
  animation: pulse-icon 2.5s ease-in-out infinite;
  }

  @keyframes pulse-icon {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.12); opacity: 0.7; }
  }

  .success-icon-inner {
  position: absolute;
  inset: 10px;
  border-radius: 50%;
  background: linear-gradient(135deg, #00bab2, #00968f);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(0,186,178,0.4);
  animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1) 0.3s both;
  }

  @keyframes popIn {
  from { transform: scale(0); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
  }

  .success-icon-inner svg {
  width: 36px;
  height: 36px;
  color: #fff;
  stroke-width: 2.5;
  animation: drawCheck 0.5s ease 0.7s both;
  }

  @keyframes drawCheck {
  from { stroke-dashoffset: 50; opacity: 0; }
  to { stroke-dashoffset: 0; opacity: 1; }
  }

  .exito-card h1 {
  font-size: 1.7rem;
  color: #fff;
  margin-bottom: 0.8rem;
  line-height: 1.25;
  }

  .exito-card .exito-subtitle {
  font-size: 0.97rem;
  color: rgba(255,255,255,0.65);
  margin-bottom: 2rem;
  line-height: 1.6;
  }

  /* Pasos de seguimiento */
  .exito-steps {
  background: rgba(0,186,178,0.06);
  border: 1px solid rgba(0,186,178,0.15);
  border-radius: 0.9rem;
  padding: 1.4rem 1.6rem;
  text-align: left;
  margin-bottom: 2rem;
  }

  .exito-steps-title {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #00eae3;
  margin-bottom: 1rem;
  }

  .exito-step-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
  }

  .exito-step-item:last-child { margin-bottom: 0; }

  .exito-step-dot {
  width: 8px;
  height: 8px;
  min-width: 8px;
  border-radius: 50%;
  background: var(--primary);
  margin-top: 6px;
  }

  .exito-step-item p {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.65);
  margin: 0;
  line-height: 1.5;
  }

  .exito-actions {
  display: flex;
  gap: 0.9rem;
  flex-wrap: wrap;
  justify-content: center;
  }

  .exito-actions a {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.6rem;
  border-radius: 50px;
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.3s ease;
  text-decoration: none;
  }

  .btn-home {
  background: var(--primary);
  color: #fff;
  border: 2px solid var(--primary);
  }

  .btn-home:hover {
  background: var(--primary-dark);
  border-color: var(--primary-dark);
  transform: translateY(-2px);
  box-shadow: 0 6px 18px rgba(0,186,178,0.3);
  color: #fff;
  }

  .btn-new-ticket {
  background: transparent;
  color: rgba(255,255,255,0.7);
  border: 2px solid rgba(255,255,255,0.15);
  }

  .btn-new-ticket:hover {
  border-color: rgba(255,255,255,0.4);
  color: #fff;
  transform: translateY(-2px);
  }

  @media (max-width: 480px) {
  .exito-card { padding: 2.5rem 1.5rem; }
  .exito-actions { flex-direction: column; }
  .exito-actions a { width: 100%; justify-content: center; }
  }
  </style>

  <section class="exito-section">
    <div class="exito-card">

      <!-- Ícono animado -->
      <div class="success-icon-wrap">
        <div class="success-icon-bg"></div>
        <div class="success-icon-inner">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
      </div>

      <h1>¡Solicitud Enviada!</h1>
      <p class="exito-subtitle">
        Tu ticket fue registrado correctamente en nuestra mesa de ayuda.<br>
        Recibirás una respuesta en el correo que indicaste.
      </p>

      <div class="exito-steps">
        <div class="exito-steps-title">¿Qué sigue?</div>
        <div class="exito-step-item">
          <div class="exito-step-dot"></div>
          <p>Nuestro equipo revisará tu requerimiento y te contactará a la brevedad.</p>
        </div>
      </div>

      <div class="exito-actions">
        <a href="/" class="btn-home">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
          Volver al inicio
        </a>
        <a href="/soporte" class="btn-new-ticket">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          Nuevo ticket
        </a>
      </div>

    </div>
  </section>

  `}) %>