# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── SMTP Google (Gmail) ─────────────────────────────────
# Usar una App Password de Google (no la contraseña de la cuenta)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password-aqui

# ─── Mesa de Ayuda FreeScout ─────────────────────────────
# Dirección de correo del buzón monitoreado por FreeScout
HELPDESK_EMAIL=soporte@tudominio.com

# ─── Seguridad / Rate Limiting ───────────────────────────
# Máximo de solicitudes por IP en 15 minutos
RATE_LIMIT_MAX=5
